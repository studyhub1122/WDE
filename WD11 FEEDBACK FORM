<!DOCTYPE html>
<html>
<head>
    <title>Feedback Form</title>
</head>
<body>

    <h1>User Feedback Form</h1>

    <form>

        <!-- Name -->
        <label>Enter Your Name:</label><br>
        <input type="text" name="name"><br><br>

        <!-- Email -->
        <label>Enter Your Email:</label><br>
        <input type="email" name="email"><br><br>

        <!-- Dropdown List -->
        <label>Select Course:</label><br>

        <select name="course">
            <option>Computer Science</option>
            <option>Information Technology</option>
            <option>Electronics</option>
            <option>Mechanical</option>
        </select>

        <br><br>

        <!-- Radio Buttons -->
        <label>Rate Our Website:</label><br>

        <input type="radio" name="rating" value="Excellent"> Excellent
        <input type="radio" name="rating" value="Good"> Good
        <input type="radio" name="rating" value="Average"> Average

        <br><br>

        <!-- Textarea -->
        <label>Write Your Feedback:</label><br>

        <textarea rows="5" cols="30"
        placeholder="Enter your feedback here"></textarea>

        <br><br>

        <!-- Buttons -->
        <input type="submit" value="Submit">

        <input type="reset" value="Reset">

    </form>

</body>
</html>
